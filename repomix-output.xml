<?php

namespace App\Models;

use Illuminate\Database\Eloquent\Factories\HasFactory;
use Illuminate\Database\Eloquent\Relations\HasMany;
use Illuminate\Foundation\Auth\User as Authenticatable;
use Illuminate\Notifications\Notifiable;
use Laravel\Sanctum\HasApiTokens;

class User extends Authenticatable
{
    use HasApiTokens, HasFactory, Notifiable;

    /** @var array<int, string> */
    protected $fillable = [
        'name',
        'email',
        'password',
        'role',
        'quiz_result',
        'quiz_scores',
        'bio',
        'tujuan_belajar',
        'jenjang',
        'no_hp',
    ];

    /** @var array<int, string> */
    protected $hidden = [
        'password',
        'remember_token',
    ];

    protected function casts(): array
    {
        return [
            'email_verified_at' => 'datetime',
            'password'          => 'hashed',
            'quiz_scores'       => 'array',
        ];
    }

    public function jurnalBelajar(): HasMany
    {
        return $this->hasMany(JurnalBelajar::class, 'user_id');
    }

    public function sesiBelajar(): HasMany
    {
        return $this->hasMany(SesiBelajar::class, 'user_id');
    }

    public function kelasDiajar(): HasMany
    {
        return $this->hasMany(Kelas::class, 'pengajar_id');
    }

    public function anggotaKelas(): HasMany
    {
        return $this->hasMany(AnggotaKelas::class, 'siswa_id');
    }

    public function isSiswa(): bool
    {
        return $this->role === 'siswa';
    }

    public function isPengajar(): bool
    {
        return $this->role === 'pengajar';
    }
}
</file>

<file path="public/css/app.css">
/* ============================================================
   LearnFit Landing Page — public/css/app.css
   ============================================================ */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
    --blue:        #2563EB;
    --blue-dark:   #1d4ed8;
    --blue-light:  #EFF4FF;
    --text-dark:   #0F172A;
    --text-mid:    #475569;
    --text-light:  #94A3B8;
    --bg:          #ffffff;
    --bg-section:  #E4EAF4;
    --card-bg:     #ffffff;
    --border:      #E2E8F0;
    --hero-bg:     #F0F4FF;
    --radius-sm:   10px;
    --radius-md:   16px;
    --radius-lg:   24px;
    --shadow-md:   0 4px 16px rgba(37,99,235,.12);
    --shadow-lg:   0 16px 48px rgba(37,99,235,.16);
    --font:        'Plus Jakarta Sans', sans-serif;
    --transition:  .25s cubic-bezier(.4,0,.2,1);
}

html { scroll-behavior: smooth; }

body {
    font-family: var(--font);
    color: var(--text-dark);
    background: var(--bg);
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
}

.container {
    width: 100%;
    max-width: 1160px;
    margin-inline: auto;
    padding-inline: 24px;
}

/* BUTTONS */
.btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font);
    font-weight: 600;
    font-size: .9rem;
    border-radius: 50px;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 10px 22px;
    text-decoration: none;
    transition: background var(--transition), color var(--transition),
                border-color var(--transition), transform var(--transition),
                box-shadow var(--transition);
    white-space: nowrap;
}
.btn--primary { background: var(--blue); color: #fff; border-color: var(--blue); }
.btn--primary:hover { background: var(--blue-dark); border-color: var(--blue-dark); box-shadow: var(--shadow-md); transform: translateY(-1px); }
.btn--ghost { background: transparent; color: var(--text-dark); border-color: var(--border); }
.btn--ghost:hover { color: var(--blue); border-color: var(--blue); box-shadow: 0 2px 8px rgba(37,99,235,.1); transform: translateY(-1px); }
.btn--lg { padding: 14px 30px; font-size: 1rem; }

/* NAVBAR */
.navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
}
.navbar__inner { display: flex; align-items: center; gap: 40px; height: 68px; }
.navbar__brand { display: flex; align-items: center; gap: 8px; text-decoration: none; flex-shrink: 0; }
.navbar__brand-name { font-weight: 700; font-size: 1.1rem; color: var(--text-dark); letter-spacing: -.5px; }
.navbar__links { display: flex; align-items: center; gap: 8px; list-style: none; margin-left: auto; }
.navbar__link { font-size: .9rem; font-weight: 500; color: var(--text-mid); text-decoration: none; padding: 6px 12px; border-radius: 8px; transition: color var(--transition), background var(--transition); }
.navbar__link:hover { color: var(--blue); background: var(--blue-light); }
.navbar__actions { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
.navbar__hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 6px; margin-left: auto; }
.navbar__hamburger span { display: block; width: 22px; height: 2px; background: var(--text-dark); border-radius: 2px; transition: transform var(--transition), opacity var(--transition); }
.navbar__hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.navbar__hamburger.open span:nth-child(2) { opacity: 0; }
.navbar__hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
.navbar__mobile { display: none; flex-direction: column; gap: 4px; padding: 16px 24px 20px; border-top: 1px solid var(--border); background: #fff; }
.navbar__mobile.open { display: flex; }
.navbar__mobile .navbar__link { padding: 10px 12px; }
.navbar__mobile-actions { display: flex; gap: 10px; margin-top: 12px; }

/* HERO */
.hero { background: var(--hero-bg); padding: 60px 0 40px; overflow: hidden; position: relative; }
.hero__inner { display: grid; grid-template-columns: 1fr 1fr; align-items: center; gap: 48px; position: relative; z-index: 1; }

.hero__badge {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: .72rem; font-weight: 700; letter-spacing: .12em;
    color: var(--blue); background: var(--blue-light);
    border: 1px solid rgba(37,99,235,.2);
    padding: 5px 14px; border-radius: 50px; margin-bottom: 20px;
    text-transform: uppercase;
}
.hero__title { font-size: clamp(2.4rem, 4.5vw, 3.4rem); font-weight: 800; line-height: 1.08; letter-spacing: -1.5px; color: var(--text-dark); margin-bottom: 20px; }
.hero__desc { font-size: 1rem; line-height: 1.7; color: var(--text-mid); max-width: 400px; margin-bottom: 36px; }
.hero__cta { box-shadow: var(--shadow-md); }
.hero__dots { display: flex; align-items: center; gap: 8px; margin-top: 24px; }
.dot { width: 8px; height: 8px; border-radius: 50%; background: #CBD5E1; }
.dot--active { width: 24px; border-radius: 4px; background: var(--blue); }

.hero__visual { display: flex; justify-content: center; align-items: center; }
.hero__img-wrapper {
    position: relative; width: 100%; max-width: 480px;
    border-radius: var(--radius-lg); overflow: hidden;
    background: #f5e6d3; box-shadow: var(--shadow-lg);
    border: 2px dashed rgba(37,99,235,.3);
    min-height: 340px;
}
.hero__img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
.hero__img-fallback {
    width: 100%; min-height: 340px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #f5e6d3 60%, #e8d5b8 100%);
    gap: 12px; padding: 40px;
}
.hero__img-fallback p { font-size: .82rem; color: var(--text-mid); text-align: center; }

.hero__badge-card {
    position: absolute; bottom: 20px; right: 16px;
    display: flex; align-items: center; gap: 10px;
    background: #fff; border-radius: var(--radius-sm);
    padding: 10px 16px; box-shadow: 0 4px 20px rgba(0,0,0,.14);
    animation: floatCard 3s ease-in-out infinite; z-index: 2;
}
@keyframes floatCard { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
.badge-card__title { font-size: .8rem; font-weight: 700; color: var(--text-dark); white-space: nowrap; }
.badge-card__sub { font-size: .7rem; color: var(--text-light); white-space: nowrap; }

/* FEATURES */
.features { background: var(--bg-section); padding: 32px 0 36px; }
.features__grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
.feature-card {
    background: var(--card-bg); border: 1px solid var(--border);
    border-radius: var(--radius-md); padding: 32px 28px;
    display: flex; flex-direction: column; gap: 12px;
    transition: transform var(--transition), box-shadow var(--transition);
}
.feature-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
.feature-card__icon {
    width: 48px; height: 48px; background: var(--blue-light);
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
}
.feature-card__title { font-size: 1rem; font-weight: 700; color: var(--text-dark); }
.feature-card__desc { font-size: .875rem; color: var(--text-mid); line-height: 1.6; }

/* ANIMASI — hanya aktif setelah JS menambahkan .js-loaded ke <body> */
body.js-loaded [data-animate] {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity .6s ease, transform .6s ease;
    transition-delay: var(--delay, 0ms);
}
body.js-loaded [data-animate="fade-left"] { transform: translateX(40px); }
body.js-loaded [data-animate].visible { opacity: 1; transform: translate(0,0); }

/* RESPONSIVE */
@media (max-width: 900px) {
    .hero__inner { grid-template-columns: 1fr; gap: 40px; text-align: center; }
    .hero__desc { max-width: 100%; margin-inline: auto; }
    .hero__dots { justify-content: center; }
    .hero__visual { order: -1; }
    .hero__img-wrapper { max-width: 360px; margin-inline: auto; }
    .features__grid { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
    .navbar__links, .navbar__actions { display: none; }
    .navbar__hamburger { display: flex; }
    .hero { padding: 48px 0 56px; }
    .hero__title { font-size: 2.2rem; }
}

/* ============================================================
   TESTIMONIALS
   ============================================================ */
.testimonials {
    background: var(--bg);
    padding: 36px 0 44px;
}

.section-header {
    text-align: center;
    margin-bottom: 36px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
}

.section-badge {
    display: inline-flex;
    align-items: center;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .12em;
    color: var(--blue);
    background: var(--blue-light);
    border: 1px solid rgba(37,99,235,.2);
    padding: 5px 14px;
    border-radius: 50px;
    text-transform: uppercase;
}

.section-title {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -1px;
    color: var(--text-dark);
}

.section-desc {
    font-size: .95rem;
    color: var(--text-mid);
    max-width: 500px;
    line-height: 1.7;
}

/* Grid testimoni */
.testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 48px;
}

/* Kartu testimoni */
.testi-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: transform var(--transition), box-shadow var(--transition);
}
.testi-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
}
.testi-card--featured {
    background: var(--blue);
    border-color: var(--blue);
}
.testi-card--featured .testi-card__text,
.testi-card--featured .testi-card__name { color: #fff; }
.testi-card--featured .testi-card__role { color: rgba(255,255,255,.7); }

.testi-card__stars {
    display: flex;
    gap: 3px;
}

.testi-card__text {
    font-size: .9rem;
    line-height: 1.7;
    color: var(--text-mid);
    flex: 1;
}

.testi-card__author {
    display: flex;
    align-items: center;
    gap: 12px;
}

.testi-card__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: .95rem;
    color: #fff;
    flex-shrink: 0;
}

.testi-card__name {
    font-size: .88rem;
    font-weight: 700;
    color: var(--text-dark);
}

.testi-card__role {
    font-size: .78rem;
    color: var(--text-light);
}

/* Stats bar */
.testi-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    background: var(--hero-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 32px 40px;
    flex-wrap: wrap;
    gap: 24px;
}

.testi-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
}

.testi-stat__num {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--blue);
    letter-spacing: -1px;
}

.testi-stat__label {
    font-size: .8rem;
    color: var(--text-mid);
    font-weight: 500;
}

.testi-stat__divider {
    width: 1px;
    height: 48px;
    background: var(--border);
}

/* ============================================================
   CTA BOTTOM
   ============================================================ */
.cta-bottom {
    background: var(--blue);
    padding: 64px 0;
}

.cta-bottom__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
}

.cta-bottom__title {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -.5px;
    margin-bottom: 8px;
}

.cta-bottom__desc {
    font-size: .95rem;
    color: rgba(255,255,255,.75);
    line-height: 1.6;
    max-width: 480px;
}

.btn--white {
    background: #fff;
    color: var(--blue);
    border-color: #fff;
    font-weight: 700;
    flex-shrink: 0;
}
.btn--white:hover {
    background: #f0f7ff;
    border-color: #f0f7ff;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,.15);
}

/* ============================================================
   FOOTER
   ============================================================ */
.footer {
    background: var(--bg-section);
    border-top: 1px solid var(--border);
    padding: 32px 0;
}

.footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
}

.footer__brand {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.footer__tagline {
    font-size: .82rem;
    color: var(--text-light);
    max-width: 280px;
}

.footer__copy {
    font-size: .82rem;
    color: var(--text-light);
}

/* ============================================================
   RESPONSIVE TAMBAHAN
   ============================================================ */
@media (max-width: 900px) {
    .testimonials__grid { grid-template-columns: 1fr 1fr; }
    .cta-bottom__inner { flex-direction: column; text-align: center; }
    .cta-bottom__desc { margin-inline: auto; }
    .testi-stat__divider { display: none; }
}

@media (max-width: 600px) {
    .testimonials__grid { grid-template-columns: 1fr; }
    .testi-stats { flex-direction: column; gap: 20px; padding: 28px 24px; }
    .footer__inner { flex-direction: column; align-items: flex-start; }
}

/* ============================================================
   HERO DECORATIVE ELEMENTS
   ============================================================ */

/* Blob blur kiri atas */
.hero::before {
    content: '';
    position: absolute;
    width: 380px;
    height: 380px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(147,174,255,.55) 0%, transparent 68%);
    filter: blur(60px);
    top: -100px;
    left: -100px;
    pointer-events: none;
    z-index: 0;
}

/* Blob blur kanan bawah */
.hero::after {
    content: '';
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(147,174,255,.45) 0%, transparent 68%);
    filter: blur(60px);
    bottom: -60px;
    right: -60px;
    pointer-events: none;
    z-index: 0;
}

/* Titik-titik dekoratif kiri bawah */
.hero__dots-deco {
    position: absolute;
    left: 0;
    bottom: 20px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
    opacity: .18;
    pointer-events: none;
    z-index: 0;
}
.hero__dots-deco span {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--blue);
    display: block;
}

/* Titik-titik dekoratif kanan atas */
.hero__dots-deco-r {
    position: absolute;
    right: 0;
    top: 20px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
    opacity: .18;
    pointer-events: none;
    z-index: 0;
}
.hero__dots-deco-r span {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--blue);
    display: block;
}

/* ============================================================
   AUTH PAGE (Register & Login)
   ============================================================ */
.auth-page {
    min-height: 100vh;
    background: var(--hero-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-bottom: 48px;
    position: relative;
    overflow: hidden;
}

/* Blob dekorasi */
.auth-page__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
}
.auth-page__blob--1 {
    width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(147,174,255,.5) 0%, transparent 70%);
    top: -120px; left: -120px;
}
.auth-page__blob--2 {
    width: 320px; height: 320px;
    background: radial-gradient(circle, rgba(147,174,255,.4) 0%, transparent 70%);
    bottom: -80px; right: -80px;
}

/* Auth Navbar */
.auth-nav {
    width: 100%;
    max-width: 1160px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    position: relative;
    z-index: 2;
}
.auth-nav__back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: .85rem;
    font-weight: 500;
    color: var(--text-mid);
    text-decoration: none;
    padding: 7px 14px;
    border-radius: 50px;
    border: 1px solid var(--border);
    background: #fff;
    transition: color var(--transition), border-color var(--transition), box-shadow var(--transition);
}
.auth-nav__back:hover {
    color: var(--blue);
    border-color: var(--blue);
    box-shadow: 0 2px 8px rgba(37,99,235,.1);
}

/* Card */
.auth-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 40px 40px 36px;
    width: 100%;
    max-width: 500px;
    box-shadow: 0 8px 40px rgba(37,99,235,.1);
    position: relative;
    z-index: 2;
    margin-inline: auto;      /* ← tambahkan ini untuk centering */
}

.auth-card__header { margin-bottom: 28px; }
.auth-card__title { font-size: 1.9rem; font-weight: 800; letter-spacing: -.8px; color: var(--text-dark); margin-bottom: 6px; }
.auth-card__sub { font-size: .9rem; color: var(--text-mid); }

/* Alert */
.alert {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 16px;
    border-radius: 10px;
    margin-bottom: 20px;
    font-size: .85rem;
}
.alert--error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #b91c1c;
}
.alert ul { padding-left: 4px; list-style: none; }
.alert li::before { content: "• "; }

/* Form */
.auth-form { display: flex; flex-direction: column; gap: 18px; }

.form-group { display: flex; flex-direction: column; gap: 6px; }
.form-label { font-size: .82rem; font-weight: 600; color: var(--text-dark); }

.input-wrapper { position: relative; display: flex; align-items: center; }
.form-input {
    width: 100%;
    padding: 11px 42px 11px 14px;
    font-family: var(--font);
    font-size: .9rem;
    color: var(--text-dark);
    background: #f8fafc;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    outline: none;
    transition: border-color var(--transition), box-shadow var(--transition), background var(--transition);
}
.form-input:focus {
    border-color: var(--blue);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(37,99,235,.1);
}
.form-input--error { border-color: #ef4444; }
.form-input--error:focus { box-shadow: 0 0 0 3px rgba(239,68,68,.1); }
.form-input::placeholder { color: #cbd5e1; }

.input-icon {
    position: absolute;
    right: 13px;
    color: #94a3b8;
    pointer-events: none;
    display: flex;
    align-items: center;
}
.input-icon--btn {
    pointer-events: all;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
}
.input-icon--btn:hover svg path,
.input-icon--btn:hover svg circle { stroke: var(--blue); }

.form-error { font-size: .78rem; color: #ef4444; margin-top: 2px; }
.form-link { color: var(--blue); text-decoration: none; font-weight: 500; }
.form-link:hover { text-decoration: underline; }
.form-link--bold { font-weight: 700; }

/* Role selector */
.role-selector { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.role-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 16px 12px;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    cursor: pointer;
    transition: border-color var(--transition), background var(--transition), box-shadow var(--transition);
    color: var(--text-mid);
    text-align: center;
    user-select: none;
}
.role-card:hover { border-color: var(--blue); background: var(--blue-light); }
.role-card--active {
    border-color: var(--blue);
    background: var(--blue-light);
    color: var(--blue);
    box-shadow: 0 0 0 3px rgba(37,99,235,.12);
}
.role-card__name { font-size: .88rem; font-weight: 700; }
.role-card__desc { font-size: .75rem; color: var(--text-light); }
.role-card--active .role-card__desc { color: var(--blue); opacity: .8; }

/* Checkbox */
.checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    cursor: pointer;
}
.checkbox-input { display: none; }
.checkbox-box {
    width: 18px;
    height: 18px;
    border: 1.5px solid var(--border);
    border-radius: 5px;
    flex-shrink: 0;
    margin-top: 1px;
    transition: border-color var(--transition), background var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f8fafc;
}
.checkbox-input:checked + .checkbox-box {
    background: var(--blue);
    border-color: var(--blue);
}
.checkbox-input:checked + .checkbox-box::after {
    content: '';
    display: block;
    width: 4px;
    height: 8px;
    border: 2px solid #fff;
    border-top: none;
    border-left: none;
    transform: rotate(45deg) translateY(-1px);
}
.checkbox-text { font-size: .82rem; color: var(--text-mid); line-height: 1.6; }

/* Submit button */
.btn-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 13px;
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    background: var(--blue);
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: background var(--transition), transform var(--transition), box-shadow var(--transition);
    margin-top: 4px;
}
.btn-submit:hover {
    background: var(--blue-dark);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(37,99,235,.3);
}
.btn-submit:active { transform: translateY(0); }

/* Footer text */
.auth-card__footer {
    text-align: center;
    font-size: .85rem;
    color: var(--text-mid);
    margin-top: 20px;
}

/* Responsive */
@media (max-width: 540px) {
    .auth-card { padding: 28px 20px 24px; border-radius: 16px; margin-inline: 16px; width: calc(100% - 32px); }
