    public function test_pengajar_bisa_lihat_daftar_kelas(): void
    {
        $pengajar = User::factory()->pengajar()->create();
        Kelas::factory()->count(3)->create();

        $this->actingAs($pengajar)
             ->get('/dashboard/kelas')
             ->assertStatus(200);
    }

    // ── Update ────────────────────────────────────────────────────────────────

    public function test_pengajar_bisa_update_kelas(): void
    {
        $pengajar = User::factory()->pengajar()->create();
